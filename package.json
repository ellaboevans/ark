{
  "name": "ark",
  "displayName": "Ark",
  "description": "Backup and restore your VS Code extensions and settings to a private GitHub Gist",
  "version": "1.0.0",
  "publisher": "ark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/ark.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ark.backup",
        "title": "Ark: Backup now"
      },
      {
        "command": "ark.restore",
        "title": "Ark: Restore from backup"
      },
      {
        "command": "ark.setPat",
        "title": "Ark: Set GitHub token"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --watch",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
